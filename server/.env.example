PORT=8000
HOST=0.0.0.0
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET=generate-a-long-random-string-at-least-32-chars
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EMAIL_USER=
EMAIL_PASS=

# Set to "production" on Railway. Controls whether stack traces are shown in errors.
NODE_ENV=development

# Comma-separated browser origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5173

# Base URL of the web app (password-reset links in email)
CLIENT_ORIGIN=http://localhost:5173

# Comma-separated admin emails (category mutations; full report list)
ADMIN_EMAILS=you@st.knust.edu.gh
