PORT=8000
HOST=0.0.0.0
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET=generate-a-long-random-string
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EMAIL_USER=
EMAIL_PASS=

# Set to "production" on Railway. Controls whether stack traces are shown in API errors.
NODE_ENV=development

# Comma-separated browser origins allowed to call this API
# Dev: http://localhost:5173 | Prod: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Base URL of the web app (used in password-reset email links)
CLIENT_ORIGIN=http://localhost:5173

# Comma-separated admin emails (category CRUD; full report list)
ADMIN_EMAILS=you@st.knust.edu.gh
